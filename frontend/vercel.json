{
  "installCommand": "npm install --include=dev",
  "buildCommand": "vite build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://alpb-analytics.com https://www.alpb-analytics.com"
        }
      ]
    }
  ]
}
